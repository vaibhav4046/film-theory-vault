# TMDB API key for the multi-movie search/ingestion proxy (/api/tmdb).
# Free + instant: https://www.themoviedb.org/settings/api  (v3 "API Key")
# Add it to Vercel:  Project > Settings > Environment Variables > TMDB_API_KEY
# or via CLI:        vercel env add TMDB_API_KEY
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Free LLM key for the Theory Synthesis Agent (/api/theories). Generates fan theories per movie.
# Free + instant: https://console.groq.com/keys  (no credit card)
# Optional model override (default llama-3.3-70b-versatile): GROQ_MODEL
GROQ_API_KEY=your_groq_api_key_here
